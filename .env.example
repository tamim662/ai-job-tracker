# ─── Database ─────────────────────────────────────────────────────────────────
# Option A: Docker (local) — matches docker-compose.yml defaults
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jobtracker
DB_USER=jobtracker
DB_PASSWORD=jobtracker

# Option B: AWS RDS — replace above with your RDS endpoint
# DB_HOST=your-instance.xxxx.ap-southeast-2.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=jobtracker
# DB_USER=your_rds_username
# DB_PASSWORD=your_rds_password

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate one:
#   openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=change-this-to-a-very-long-random-secret-key-at-least-32-chars

# ─── App Credentials (single user — no registration) ──────────────────────────
APP_USERNAME=admin
APP_PASSWORD=changeme

# ─── AWS S3 (optional — for resume/cover letter file storage) ─────────────────
# If you skip S3, the app will still work but file uploads will fail.
# Create a private S3 bucket and an IAM user with s3:PutObject / s3:DeleteObject.
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_BUCKET_NAME=your-s3-bucket-name
AWS_REGION=ap-southeast-2

# ─── Anthropic Claude API ─────────────────────────────────────────────────────
# Used for: outreach message generation, cover letter customisation, company research
# Get your key: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ─── Groq API (free) ──────────────────────────────────────────────────────────
# Used for: ATS resume scanning (Llama 3.3 70B — saves Anthropic tokens)
# Get your key: https://console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key-here

# ─── Adzuna Job Search API (free) ─────────────────────────────────────────────
# Used for: searching Australian job listings
# Register at: https://developer.adzuna.com
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key

# ─── Tavily Search API (free) ─────────────────────────────────────────────────
# Used for: live web search during company research
# Get your key: https://tavily.com
TAVILY_API_KEY=tvly-your-tavily-api-key-here
